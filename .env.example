# ArcInvoice Pro — environment variables
# Copy this file to `.env.local` and fill in values as needed:
#   cp .env.example .env.local
#
# Never commit real secrets. `.env*` files are gitignored (except this example).

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=ArcInvoice Pro
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL + Drizzle)
# -----------------------------------------------------------------------------
# Local example (create the database first):
#   createdb arcinvoice_pro
#   # or: psql -c 'CREATE DATABASE arcinvoice_pro;'
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arcinvoice_pro

# Optional: analytics / third-party (add when integrating features)
# NEXT_PUBLIC_ANALYTICS_ID=

# Optional: server-only secrets (add when integrating features)
# AUTH_SECRET=
