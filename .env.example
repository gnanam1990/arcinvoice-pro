# ArcInvoice Pro — environment variables
# Copy this file to `.env.local` and fill in values as needed:
#   cp .env.example .env.local
#
# Never commit real secrets. `.env*` files are gitignored (except this example).

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=ArcInvoice Pro
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL + Drizzle)
# -----------------------------------------------------------------------------
# Local example (create the database first):
#   createdb arcinvoice_pro
#   # or: psql -c 'CREATE DATABASE arcinvoice_pro;'
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arcinvoice_pro

# Organization slug used by the dashboard (defaults to seeded demo org)
# DEMO_ORGANIZATION_SLUG=demo-northline

# -----------------------------------------------------------------------------
# Arc Testnet (wallet + public payments)
# -----------------------------------------------------------------------------
# Official defaults are used when unset.
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_ARC_FAUCET_URL=https://faucet.circle.com
NEXT_PUBLIC_ARC_NETWORK_LABEL=Arc Testnet

# Optional fallback merchant wallet for display only (prefer org settings)
# NEXT_PUBLIC_MERCHANT_WALLET=0x...

# Legacy explorer template (receipts); prefer NEXT_PUBLIC_ARC_EXPLORER_URL
# NEXT_PUBLIC_EXPLORER_TX_URL=https://testnet.arcscan.app/tx/{hash}

# Optional: analytics / third-party (add when integrating features)
# NEXT_PUBLIC_ANALYTICS_ID=

# Optional: server-only secrets (add when integrating features)
# AUTH_SECRET=
